---
import { waLink } from "../data/site.js";

interface Props {
  message: string;
  label?: string;
  variant?: "primary" | "outline" | "ghost";
  size?: "md" | "lg";
  class?: string;
}

const {
  message,
  label = "Escribir por WhatsApp",
  variant = "primary",
  size = "md",
  class: className = "",
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-full font-display font-semibold uppercase tracking-wide transition-transform duration-150 active:scale-95 focus-visible:outline-2";

const sizes = {
  md: "px-5 py-3 text-sm",
  lg: "px-7 py-4 text-base",
};

const variants = {
  // Fondo verde WhatsApp real + texto oscuro para cumplir contraste AA
  primary: "bg-brand-green text-brand-bg hover:bg-brand-green/90 shadow-lg shadow-brand-green/20",
  outline: "border-2 border-brand-green text-brand-green hover:bg-brand-green/10",
  ghost: "text-brand-green hover:bg-brand-green/10",
};
---

<a
  href={waLink(message)}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[base, sizes[size], variants[variant], className]}
  aria-label={`${label} (se abre en una nueva pestaña)`}
>
  <svg
    aria-hidden="true"
    focusable="false"
    viewBox="0 0 24 24"
    class="h-4 w-4 shrink-0 fill-current"
  >
    <path
      d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.28-1.38a9.9 9.9 0 0 0 4.76 1.21h.01c5.46 0 9.9-4.45 9.9-9.91C22 6.45 17.5 2 12.04 2zm5.8 14.06c-.24.68-1.4 1.3-1.93 1.38-.5.08-1.12.11-1.8-.11-.42-.13-.96-.31-1.65-.6-2.9-1.25-4.8-4.17-4.94-4.36-.14-.19-1.18-1.57-1.18-3 0-1.42.75-2.12 1.01-2.41.27-.29.58-.36.78-.36.19 0 .39 0 .56.01.18.01.42-.07.65.5.24.58.82 2 .9 2.14.07.15.12.32.02.51-.1.19-.15.31-.29.48-.15.17-.31.38-.44.51-.15.15-.3.31-.13.6.17.29.76 1.26 1.64 2.04 1.12 1 2.06 1.31 2.35 1.46.29.15.46.13.63-.08.17-.2.72-.84.92-1.13.19-.29.39-.24.65-.14.27.1 1.68.79 1.97.94.29.14.48.21.55.33.07.13.07.7-.17 1.38z"
    ></path>
  </svg>
  {label}
</a>
